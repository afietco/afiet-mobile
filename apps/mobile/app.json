{
  "expo": {
    "name": "afiet",
    "slug": "afiet",
    "version": "0.6.0",
    "orientation": "portrait",
    "backgroundColor": "#059669",
    "icon": "./assets/images/icon.png",
    "scheme": [
      "afiet",
      "stack-auth-mobile-oauth-url"
    ],
    "platforms": [
      "ios",
      "android"
    ],
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "co.afiet.app",
      "usesAppleSignIn": true,
      "associatedDomains": [
        "applinks:afiet.co"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.co.afiet.app"
        ]
      },
      "appleTeamId": "93C5KZXLN4"
    },
    "android": {
      "package": "co.afiet.app",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.VIBRATE"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ],
      "intentFilters": [
        {
          "autoVerify": true,
          "action": "VIEW",
          "data": {
            "scheme": "https",
            "host": "afiet.co",
            "pathPrefix": "/katil"
          },
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#059669",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "splash": {
      "image": "./assets/images/splash-screen.png",
      "resizeMode": "contain",
      "backgroundColor": "#059669"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#059669",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 160
        }
      ],
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "photosPermission": "Fotoğraf seçebilmen için galeri erişimine izin ver.",
          "cameraPermission": "Fotoğraf çekebilmen için kamera erişimine izin ver.",
          "microphonePermission": false
        }
      ],
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#059669",
          "defaultChannel": "hatirlatmalar"
        }
      ],
      "@bacons/apple-targets",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "AfiyetRitmi",
              "label": "afiet · ritim",
              "description": "Haftalık afiyet ritmin ve tek dokunuşla öğün ekleme",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "targetCellWidth": 3,
              "targetCellHeight": 2,
              "updatePeriodMillis": 1800000,
              "resizeMode": "horizontal|vertical",
              "widgetFeatures": "reconfigurable"
            }
          ]
        }
      ],
      "expo-secure-store",
      [
        "@sentry/react-native/expo",
        {
          "organization": "afiet",
          "project": "afiet-mobile",
          "url": "https://sentry.io/"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "62b99f42-2103-4f87-9ec6-12abd759bda4"
      }
    },
    "owner": "rberkkaratas"
  }
}
